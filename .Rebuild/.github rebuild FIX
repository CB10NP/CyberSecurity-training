<!DOCTYPE html>  
<html lang="en">  
<head>  
    <meta charset="UTF-8" />  
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />  
    <title>GitHub File Explorer</title>  
    <style>  
        /* ===== GLOBAL RESET ===== */  
        * {  
            margin: 0;  
            padding: 0;  
            box-sizing: border-box;  
        }  

        body {  
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen,  
                Ubuntu, Cantarell, "Open Sans", "Helvetica Neue", sans-serif;  
            background-color: #0d1117;  
            color: #c9d1d9;  
            min-height: 100vh;  
            display: flex;  
            justify-content: center;  
            padding: 40px 20px;  
        }  

        /* ===== MAIN CONTAINER ===== */  
        .repo-container {  
            width: 100%;  
            max-width: 960px;  
            background: #161b22;  
            border: 1px solid #30363d;  
            border-radius: 8px;  
            overflow: hidden;  
        }  

        /* ===== REPO HEADER ===== */  
        .repo-header {  
            display: flex;  
            align-items: center;  
            justify-content: space-between;  
            padding: 16px 20px;  
            border-bottom: 1px solid #30363d;  
            flex-wrap: wrap;  
            gap: 12px;  
        }  

        .repo-header-left {  
            display: flex;  
            align-items: center;  
            gap: 10px;  
        }  

        .repo-header-left svg {  
            fill: #8b949e;  
        }  

        .repo-name {  
            font-size: 16px;  
            font-weight: 600;  
            color: #58a6ff;  
        }  

        .repo-badge {  
            font-size: 12px;  
            padding: 2px 8px;  
            border: 1px solid #30363d;  
            border-radius: 20px;  
            color: #8b949e;  
        }  

        .repo-header-right {  
            display: flex;  
            gap: 8px;  
        }  

        .btn {  
            display: flex;  
            align-items: center;  
            gap: 6px;  
            padding: 5px 14px;  
            font-size: 13px;  
            font-weight: 500;  
            border: 1px solid #30363d;  
            border-radius: 6px;  
            background: #21262d;  
            color: #c9d1d9;  
            cursor: pointer;  
            transition: background 0.2s;  
        }  

        .btn:hover {  
            background: #30363d;  
        }  

        .btn svg {  
            fill: #8b949e;  
        }  

        /* ===== BREADCRUMB ===== */  
        .breadcrumb-bar {  
            display: flex;  
            align-items: center;  
            flex-wrap: wrap;  
            gap: 6px;  
            padding: 12px 20px;  
            border-bottom: 1px solid #30363d;  
            font-size: 14px;  
            background: #0d1117;  
        }  

        .breadcrumb-item {  
            color: #58a6ff;  
            cursor: pointer;  
            transition: color 0.15s;  
        }  

        .breadcrumb-item:hover {  
            color: #79c0ff;  
            text-decoration: underline;  
        }  

        .breadcrumb-separator {  
            color: #484f58;  
            font-size: 16px;  
        }  

        .breadcrumb-current {  
            color: #c9d1d9;  
            font-weight: 600;  
        }  

        /* ===== SEARCH BAR ===== */  
        .search-bar {  
            padding: 12px 20px;  
            border-bottom: 1px solid #30363d;  
        }  

        .search-bar input {  
            width: 100%;  
            padding: 8px 12px;  
            background: #0d1117;  
            border: 1px solid #30363d;  
            border-radius: 6px;  
            color: #c9d1d9;  
            font-size: 14px;  
            outline: none;  
            transition: border-color 0.2s;  
        }  

        .search-bar input::placeholder {  
            color: #484f58;  
        }  

        .search-bar input:focus {  
            border-color: #58a6ff;  
        }  

        /* ===== FILE LIST ===== */  
        .file-list-header {  
            display: flex;  
            justify-content: space-between;  
            padding: 10px 20px;  
            font-size: 12px;  
            color: #8b949e;  
            border-bottom: 1px solid #30363d;  
            background: #0d1117;  
        }  

        .file-list {  
            list-style: none;  
        }  

        .file-item {  
            display: flex;  
            align-items: center;  
            justify-content: space-between;  
            padding: 8px 20px;  
            border-bottom: 1px solid #21262d;  
            cursor: pointer;  
            transition: background 0.15s;  
        }  

        .file-item:hover {  
            background: #1c2128;  
        }  

        .file-item-left {  
            display: flex;  
            align-items: center;  
            gap: 12px;  
            flex: 1;  
            min-width: 0;  
        }  

        .file-item-icon {  
            flex-shrink: 0;  
            display: flex;  
            align-items: center;  
        }  

        .file-item-icon svg {  
            display: block;  
        }  

        .file-item-name {  
            font-size: 14px;  
            color: #c9d1d9;  
            overflow: hidden;  
            text-overflow: ellipsis;  
            white-space: nowrap;  
        }  

        .file-item-name.folder {  
            color: #58a6ff;  
            font-weight: 500;  
        }  

        .file-item-name.folder:hover {  
            text-decoration: underline;  
        }  

        .file-item-arrow {  
            flex-shrink: 0;  
            margin-right: 4px;  
            transition: transform 0.2s;  
            color: #8b949e;  
        }  

        .file-item-arrow.open {  
            transform: rotate(90deg);  
        }  

        .file-item-right {  
            display: flex;  
            align-items: center;  
            gap: 20px;  
            flex-shrink: 0;  
        }  

        .file-item-message {  
            font-size: 12px;  
            color: #8b949e;  
            max-width: 200px;  
            overflow: hidden;  
            text-overflow: ellipsis;  
            white-space: nowrap;  
        }  

        .file-item-date {  
            font-size: 12px;  
            color: #8b949e;  
            white-space: nowrap;  
        }  

        /* ===== NESTED FOLDER ===== */  
        .nested {  
            display: none;  
        }  

        .nested.active {  
            display: block;  
        }  

        .nested .file-item {  
            padding-left: 52px;  
        }  

        .nested .nested .file-item {  
            padding-left: 84px;  
        }  

        .nested .nested .nested .file-item {  
            padding-left: 116px;  
        }  

        .nested .nested .nested .nested .file-item {  
            padding-left: 148px;  
        }  

        /* ===== EMPTY STATE ===== */  
        .empty-state {  
            text-align: center;  
            padding: 48px 20px;  
            color: #8b949e;  
        }  

        .empty-state svg {  
            margin-bottom: 12px;  
            fill: #484f58;  
        }  

        .empty-state p {  
            font-size: 16px;  
        }  

        /* ===== GO BACK BUTTON ===== */  
        .go-back {  
            display: flex;  
            align-items: center;  
            gap: 6px;  
            padding: 8px 20px;  
            font-size: 13px;  
            color: #58a6ff;  
            cursor: pointer;  
            border-bottom: 1px solid #30363d;  
            transition: background 0.15s;  
        }  

        .go-back:hover {  
            background: #1c2128;  
        }  

        /* ===== RESPONSIVE ===== */  
        @media (max-width: 600px) {  
            .repo-header {  
                flex-direction: column;  
                align-items: flex-start;  
            }  
            .file-item-message {  
                display: none;  
            }  
            .file-item-date {  
                font-size: 11px;  
            }  
            .nested .file-item {  
                padding-left: 40px;  
            }  
            .nested .nested .file-item {  
                padding-left: 60px;  
            }  
            .nested .nested .nested .file-item {  
                padding-left: 80px;  
            }  
            .nested .nested .nested .nested .file-item {  
                padding-left: 100px;  
            }  
        }  
    </style>  
</head>  
