<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Acme Corp · GitHub</title>
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background-color: #0d1117;
            color: #c9d1d9;
            line-height: 1.6;
        }

        /* ----- Header / Nav Bar ----- */
        .top-nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 24px;
            background-color: #161b22;
            border-bottom: 1px solid #30363d;
        }

        .top-nav .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 20px;
            font-weight: 700;
            color: #f0f6fc;
        }

        .top-nav .logo i {
            font-size: 28px;
            color: #58a6ff;
        }

        .nav-links a {
            color: #8b949e;
            margin-left: 24px;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: color 0.2s;
        }

        .nav-links a:hover {
            color: #58a6ff;
        }

        /* ----- Organization Header ----- */
        .org-header {
            max-width: 1280px;
            margin: 0 auto;
            padding: 40px 24px 24px;
            display: flex;
            align-items: center;
            gap: 24px;
            flex-wrap: wrap;
        }

        .org-avatar {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: linear-gradient(135deg, #238636, #58a6ff);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 48px;
            color: #fff;
            flex-shrink: 0;
            border: 3px solid #30363d;
        }

        .org-info h1 {
            font-size: 28px;
            font-weight: 700;
            color: #f0f6fc;
        }

        .org-info .tagline {
            font-size: 16px;
            color: #8b949e;
            margin-top: 4px;
        }

        .org-info .meta {
            margin-top: 10px;
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            font-size: 14px;
            color: #8b949e;
        }

        .org-info .meta i {
            margin-right: 6px;
            color: #58a6ff;
        }

        .org-info .meta span {
            display: inline-flex;
            align-items: center;
        }

        /* ----- Tab Bar ----- */
        .tab-bar {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 24px;
            border-bottom: 1px solid #30363d;
            display: flex;
            gap: 0;
            overflow-x: auto;
        }

        .tab-bar a {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 12px 16px;
            color: #8b949e;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            border-bottom: 2px solid transparent;
            transition: 0.2s;
            white-space: nowrap;
        }

        .tab-bar a.active {
            color: #f0f6fc;
            border-bottom-color: #f78166;
        }

        .tab-bar a:hover:not(.active) {
            color: #c9d1d9;
            border-bottom-color: #30363d;
        }

        /* ----- Main Content ----- */
        .main-content {
            max-width: 1280px;
            margin: 24px auto;
            padding: 0 24px;
            display: grid;
            grid-template-columns: 1fr 320px;
            gap: 24px;
        }

        /* -- Repositories Section -- */
        .repos-section h2 {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 16px;
            color: #f0f6fc;
        }

        .repo-card {
            background: #161b22;
            border: 1px solid #30363d;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 16px;
            transition: border-color 0.2s;
        }

        .repo-card:hover {
            border-color: #58a6ff;
        }

        .repo-card .repo-name {
            font-size: 18px;
            font-weight: 600;
            color: #58a6ff;
            text-decoration: none;
        }

        .repo-card .repo-name:hover {
            text-decoration: underline;
        }

        .repo-card .repo-desc {
            font-size: 14px;
            color: #8b949e;
            margin: 6px 0 12px;
        }

        .repo-card .repo-meta {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 16px;
            font-size: 12px;
            color: #8b949e;
        }

        .repo-card .repo-meta .lang-dot {
            display: inline-block;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            margin-right: 4px;
        }

        .lang-js { background: #f1e05a; }
        .lang-py { background: #3572A5; }
        .lang-go { background: #00ADD8; }
        .lang-ts { background: #3178c6; }
        .lang-rust{ background: #dea584; }

        .repo-card .repo-meta i {
            margin-right: 4px;
        }

        /* -- Sidebar -- */
        .sidebar-section {
            background: #161b22;
            border: 1px solid #30363d;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .sidebar-section h3 {
            font-size: 14px;
            font-weight: 600;
            color: #8b949e;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 12px;
        }

        .sidebar-section p,
        .sidebar-section li {
            font-size: 14px;
            color: #c9d1d9;
        }

        .sidebar-section ul {
            list-style: none;
            padding: 0;
        }

        .sidebar-section ul li {
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .sidebar-section ul li i {
            width: 16px;
            color: #58a6ff;
        }

        .sidebar-section a {
            color: #58a6ff;
            text-decoration: none;
        }

        .sidebar-section a:hover {
            text-decoration: underline;
        }

        /* ----- Footer ----- */
        .footer {
            max-width: 1280px;
            margin: 40px auto 20px;
            padding: 0 24px;
            text-align: center;
            font-size: 12px;
            color: #484f58;
            border-top: 1px solid #21262d;
            padding-top: 20px;
        }

        .footer a {
            color: #8b949e;
            text-decoration: none;
            margin: 0 8px;
        }

        .footer a:hover {
            color: #58a6ff;
        }

        /* ----- Responsive ----- */
        @media (max-width: 768px) {
            .main-content {
                grid-template-columns: 1fr;
            }
            .org-header {
                flex-direction: column;
                align-items: flex-start;
                text-align: left;
            }
            .top-nav {
                flex-wrap: wrap;
                gap: 12px;
            }
            .nav-links a {
                margin-left: 12px;
            }
        }
    </style>
</head>
<body>

    <!-- ===== Navigation ===== -->
    <nav class="top-nav">
        <div class="logo">
            <i class="fab fa-github"></i>
            <span>Acme Corp</span>
        </div>
        <div class="nav-links">
