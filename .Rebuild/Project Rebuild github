                <div class="repo-meta">
                    <span><span class="lang-dot lang-js"></span> HCL</span>
                    <span><i class="fas fa-star"></i> 670</span>
                    <span><i class="fas fa-code-branch"></i> 144</span>
                    <span>Updated 2 weeks ago</span>
