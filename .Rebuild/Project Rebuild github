                <div class="repo-meta">
                    <span><span class="lang-dot lang-js"></span> JavaScript</span>
                    <span><i class="fas fa-star"></i> 340</span>
                    <span><i class="fas fa-code-branch"></i> 88</span>
                    <span>Updated 1 month ago</span>
                </div>
            </div>
        </section>

        <!-- Sidebar -->
        <aside>
            <!-- About -->
            <div class="sidebar-section">
                <h3>About</h3>
                <p>Acme Corporation is a technology company focused on building scalable, secure, and open-source cloud infrastructure tools.</p>
                <br />
                <p><i class="fas fa-envelope" style="margin-right:6px; color:#58a6ff;"></i> <a href="#">opensource@acme.example.com</a></p>
            </div>

            <!-- Top Languages -->
            <div class="sidebar-section">
                <h3>Top Languages</h3>
                <ul>
                    <li><i class="fas fa-circle" style="color:#f1e05a; font-size:10px;"></i> JavaScript (32%)</li>
                    <li><i class="fas fa-circle" style="color:#3178c6; font-size:10px;"></i> TypeScript (28%)</li>
                    <li><i class="fas fa-circle" style="color:#3572A5; font-size:10px;"></i> Python (18%)</li>
                    <li><i class="fas fa-circle" style="color:#00ADD8; font-size:10px;"></i> Go (14%)</li>
                    <li><i class="fas fa-circle" style="color:#dea584; font-size:10px;"></i> Rust (8%)</li>
